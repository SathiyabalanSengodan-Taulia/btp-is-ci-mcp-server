{
  "xsappname": "sbs-btp-is-ci-mcp",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "redirect-uris": [
      "https://claude.ai/api/mcp/auth_callback",
      "https://<your-app>.cfapps.<region>.hana.ondemand.com/**"
    ]
  },
  "scopes": [
    {
      "name": "$XSAPPNAME.read",
      "description": "Read SAP CPI data"
    },
    {
      "name": "$XSAPPNAME.write",
      "description": "Write/modify SAP CPI data"
    },
    {
      "name": "$XSAPPNAME.admin",
      "description": "Full admin access"
    }
  ],
  "role-templates": [
    {
      "name": "MCPViewer",
      "description": "View SAP CPI data via MCP server",
      "scope-references": [
        "$XSAPPNAME.read"
      ]
    },
    {
      "name": "MCPEditor",
      "description": "View and modify SAP CPI data via MCP server",
      "scope-references": [
        "$XSAPPNAME.read",
        "$XSAPPNAME.write"
      ]
    },
    {
      "name": "MCPAdmin",
      "description": "Full administrative access to SAP CPI via MCP server",
      "scope-references": [
        "$XSAPPNAME.read",
        "$XSAPPNAME.write",
        "$XSAPPNAME.admin"
      ]
    }
  ]
}
